# Public frontend configuration
NEXT_PUBLIC_APP_URL=https://luisromerofutbol.com
NEXT_PUBLIC_API_BASE_URL=/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_PUBLISHABLE_KEY=

# Render API configuration
API_PORT=8787
# Optional. Leave unset on Render unless the API runs in a separate service.
# API_INTERNAL_URL=http://127.0.0.1:8787
APP_ORIGIN=https://luisromerofutbol.com
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Sports provider configuration
# Sets provider priority. When both APIs are configured, the other provider is
# used automatically if the preferred one fails or returns no usable content.
SPORTS_PROVIDER=sportsrc
SPORTSRC_API_KEY=
SPORTSRC_BASE_URL=
SPORTSRC_EVENTS_PATH=GamesByDate/{date}
SPORTSRC_EVENT_PATH=Game/{id}
SPORTSRC_LIVE_EVENTS_PATH=
SPORTSRC_AUTH_HEADER=Ocp-Apim-Subscription-Key
THESPORTSDB_API_KEY=

# Streaming provider — only "custom" (RTMP/RTMPS/SRT) is currently supported.
# Set STREAM_PROVIDER=custom or leave empty to use your own RTMP/RTMPS/SRT server.
STREAM_PROVIDER=custom

# RTMP/RTMPS/SRT ingest URL for OBS sources.
# Examples:
#   rtmps://your-server.example.com:443/live
#   rtmp://your-server.example.com:1935/live
#   srt://your-server.example.com:9000
STREAM_INGEST_URL=

# Base URL where HLS playlists (.m3u8) are served from after ingest.
# The stream key will be appended as a path segment:
#   {STREAM_PLAYBACK_BASE_URL}/{streamKey}/index.m3u8
STREAM_PLAYBACK_BASE_URL=

# Optional: MediaMTX (or compatible) REST API URL for live status polling.
# When set, GET /v3/paths/list is queried every 5 seconds to detect active streams.
# Example: http://your-media-server.example.com:9997
STREAM_API_URL=

# AES-256-GCM key used to encrypt stream keys at rest. Must be ≥32 characters.
# Generate with: openssl rand -base64 32
STREAM_SECRET_KEY=

# Webhook secret for stream provider callbacks (future use).
STREAM_WEBHOOK_SECRET=

# Comma-separated list of allowed origins for streaming-related CORS validation.
STREAM_ALLOWED_ORIGINS=

# Security and API tokens
ADMIN_API_TOKEN=
ALLOWED_EMBED_DOMAINS=www.youtube.com,www.youtube-nocookie.com,player.vimeo.com

# OAuth and platform services
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
RESEND_API_KEY=

# Analytics and presence
ANALYTICS_RETENTION_DAYS=365
PRESENCE_TIMEOUT_SECONDS=90

# Development-only compatibility. Keep disabled in production.
LEGACY_AUTH_ENABLED=false
