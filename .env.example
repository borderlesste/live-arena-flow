# ═══════════════════════════════════════════════════════════════════════════════
# luisromerofutbol.com — Plantilla de variables de entorno
# Copia este archivo como .env y rellena los valores reales.
# ⚠  Nunca subas .env a Git. Solo .env.example va al repositorio.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Frontend (Next.js — expuestas al navegador) ──────────────────────────────
NEXT_PUBLIC_APP_URL=https://luisromerofutbol.com
NEXT_PUBLIC_API_BASE_URL=/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Token público del sitio en Cloudflare Web Analytics. Es seguro para el navegador.
NEXT_PUBLIC_CLOUDFLARE_WEB_ANALYTICS_TOKEN=
# URL pública del backend persistente, sin el sufijo /api. Obligatoria en Vercel.
API_INTERNAL_URL=https://live-arena-flow.onrender.com
# Secreto compartido por Vercel y el backend para autorizar el cron diario.
CRON_SECRET=

# ── Backend API (server/index.ts) ────────────────────────────────────────────
API_PORT=8787
APP_ORIGIN=https://luisromerofutbol.com

# ── Supabase (solo backend — nunca exponer al frontend) ──────────────────────
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── SportSRC V2 ──────────────────────────────────────────────────────────────
# Clave de licencia server-only. Endpoint fijo: https://api.sportsrc.org/v2/
SPORTSRC_API_KEY=

# ── Streaming ────────────────────────────────────────────────────────────────
# Proveedor activo: "custom" | "cloudflare" | "restream" | "restream_cloudflare"
STREAM_PROVIDER=custom

# -- Cloudflare Stream (activar cuando STREAM_PROVIDER=cloudflare) ------------
# Account ID: Cloudflare Dashboard → lado derecho de la página principal
CLOUDFLARE_ACCOUNT_ID=
# API Token con permiso "Stream:Write" limitado a tu cuenta.
# ⚠  Nunca exponer al frontend, logs ni source maps.
# Generar en: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_STREAM_API_TOKEN=
# Token independiente con permiso Account Analytics: Read. Solo backend.
CLOUDFLARE_ANALYTICS_API_TOKEN=
# Opcional si el backend también recibe NEXT_PUBLIC_CLOUDFLARE_WEB_ANALYTICS_TOKEN.
CLOUDFLARE_WEB_ANALYTICS_SITE_TOKEN=
CLOUDFLARE_ANALYTICS_API_TIMEOUT_MS=15000
# Código de subdominio del cliente para construir URLs HLS.
# Cloudflare Stream Dashboard → "Customer subdomain"
# URL resultante: https://customer-{CÓDIGO}.cloudflarestream.com/{uid}/manifest/video.m3u8
CLOUDFLARE_STREAM_CUSTOMER_CODE=
# Modo de grabación de nuevos Live Inputs: "off" (por defecto) | "automatic"
CLOUDFLARE_STREAM_RECORDING_MODE=automatic
# Eliminar grabaciones después de N días (dejar vacío = conservar siempre)
CLOUDFLARE_STREAM_DELETE_RECORDING_AFTER_DAYS=
# Requerir URLs firmadas para reproducción (por defecto: false)
CLOUDFLARE_STREAM_REQUIRE_SIGNED_URLS=false
# Orígenes permitidos para reproducción (separados por coma)
CLOUDFLARE_STREAM_ALLOWED_ORIGINS=luisromerofutbol.com,www.luisromerofutbol.com
# Timeout en ms para llamadas a la API de Cloudflare (por defecto: 15000)
CLOUDFLARE_STREAM_API_TIMEOUT_MS=15000
# Secreto del webhook — configúralo en Cloudflare Notifications.
# Se usa para verificar el header cf-webhook-auth en eventos entrantes.
CLOUDFLARE_STREAM_WEBHOOK_SECRET=

# -- Restream (STREAM_PROVIDER=restream o restream_cloudflare) ----------------
# Opción API: token OAuth server-only con scopes channels.read y stream.read.
RESTREAM_ACCESS_TOKEN=
# Opción estática: usar ambos valores si no se configura RESTREAM_ACCESS_TOKEN.
RESTREAM_INGEST_URL=rtmps://live.restream.io:1937/live
RESTREAM_STREAM_KEY=
RESTREAM_API_TIMEOUT_MS=15000
# Para OBS -> Restream -> Cloudflare -> HLS usa STREAM_PROVIDER=restream_cloudflare
# y configura también todas las variables CLOUDFLARE_* anteriores. El panel permite
# omitir Restream por fuente y publicar OBS directamente en Cloudflare. Para retirar
# Restream globalmente más adelante, cambia únicamente STREAM_PROVIDER=cloudflare.

# -- Servidor RTMP propio (activar cuando STREAM_PROVIDER=custom) -------------
# URL de ingestión RTMP/RTMPS/SRT donde OBS envía la señal.
STREAM_INGEST_URL=
# Compatibilidad heredada. La reproducción pública NO se deriva de esta base
# ni de la stream key; configura una URL HTTPS independiente desde el panel.
STREAM_PLAYBACK_BASE_URL=
# API REST de MediaMTX para detección de estado en vivo (opcional).
STREAM_API_URL=

# -- Seguridad de credenciales (ambos proveedores) ----------------------------
# Clave AES-256-GCM para cifrar stream keys en reposo. Mínimo 32 caracteres.
# Genera una nueva con: openssl rand -base64 32
# Obligatoria en producción con STREAM_PROVIDER=custom.
STREAM_SECRET_KEY=

# ── Seguridad y tokens ───────────────────────────────────────────────────────
# Token para acceso admin en desarrollo. Vacío en producción.
ADMIN_API_TOKEN=
ALLOWED_EMBED_DOMAINS=www.youtube.com,www.youtube-nocookie.com,player.vimeo.com

# ── Compatibilidad (solo desarrollo) ────────────────────────────────────────
# Mantener en false siempre. Solo true si usas el backend legacy de auth.
LEGACY_AUTH_ENABLED=false
