# Public frontend configuration
NEXT_PUBLIC_APP_URL=https://luisromerofutbol.com
NEXT_PUBLIC_API_BASE_URL=/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_PUBLISHABLE_KEY=

# Render API configuration
API_PORT=8787
# Optional. Leave unset on Render unless the API runs in a separate service.
# API_INTERNAL_URL=http://127.0.0.1:8787
APP_ORIGIN=https://luisromerofutbol.com
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Sports provider configuration
# Sets provider priority. When both APIs are configured, the other provider is
# used automatically if the preferred one fails or returns no usable content.
SPORTS_PROVIDER=sportsrc
SPORTSRC_API_KEY=
SPORTSRC_BASE_URL=
SPORTSRC_EVENTS_PATH=GamesByDate/{date}
SPORTSRC_EVENT_PATH=Game/{id}
SPORTSRC_LIVE_EVENTS_PATH=
SPORTSRC_AUTH_HEADER=Ocp-Apim-Subscription-Key
THESPORTSDB_API_KEY=

# Streaming provider — set STREAM_PROVIDER=cloudflare for Cloudflare Stream Live Inputs
#                     or STREAM_PROVIDER=custom for your own RTMP/RTMPS/SRT server
STREAM_PROVIDER=custom

# ── Cloudflare Stream (when STREAM_PROVIDER=cloudflare) ──────────────────────
# Your Cloudflare Account ID (found in the Cloudflare dashboard)
CLOUDFLARE_ACCOUNT_ID=

# API Token with "Stream:Write" permission, limited to your account.
# ⚠  Never expose this in the frontend, logs, or source maps.
# Generate at: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_STREAM_API_TOKEN=

# Customer subdomain code for building HLS playback URLs.
# Found in Cloudflare Stream dashboard → "Customer subdomain"
# Used to build: https://customer-{CODE}.cloudflarestream.com/{uid}/manifest/video.m3u8
CLOUDFLARE_STREAM_CUSTOMER_CODE=

# Recording mode for new Live Inputs: "off" (default) or "automatic"
CLOUDFLARE_STREAM_RECORDING_MODE=off

# Delete recordings after N days when mode=automatic (leave blank = keep forever)
CLOUDFLARE_STREAM_DELETE_RECORDING_AFTER_DAYS=

# Require signed URLs for HLS playback (default: false)
CLOUDFLARE_STREAM_REQUIRE_SIGNED_URLS=false

# Comma-separated list of allowed origins for playback
CLOUDFLARE_STREAM_ALLOWED_ORIGINS=luisromerofutbol.com,www.luisromerofutbol.com

# Timeout in milliseconds for Cloudflare API calls (default: 15000)
CLOUDFLARE_STREAM_API_TIMEOUT_MS=15000

# Webhook secret — set this to the value you configure in Cloudflare Notifications.
# Used to verify the cf-webhook-auth header on incoming webhook events.
CLOUDFLARE_STREAM_WEBHOOK_SECRET=

# ── Custom RTMP (when STREAM_PROVIDER=custom) ─────────────────────────────────
# RTMP/RTMPS/SRT ingest URL for your own media server.
STREAM_INGEST_URL=

# Base URL where HLS playlists are served from after ingest.
# Stream key is appended: {STREAM_PLAYBACK_BASE_URL}/{key}/index.m3u8
STREAM_PLAYBACK_BASE_URL=

# Optional: MediaMTX REST API for live status polling (custom provider only).
STREAM_API_URL=

# AES-256-GCM key for encrypting stream keys at rest. Must be ≥32 characters.
# Generate with: openssl rand -base64 32
# Required in production. Not needed if using Cloudflare provider (keys fetched on demand).
STREAM_SECRET_KEY=

# Security and API tokens
ADMIN_API_TOKEN=
ALLOWED_EMBED_DOMAINS=www.youtube.com,www.youtube-nocookie.com,player.vimeo.com

# OAuth and platform services
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
RESEND_API_KEY=

# Analytics and presence
ANALYTICS_RETENTION_DAYS=365
PRESENCE_TIMEOUT_SECONDS=90

# Development-only compatibility. Keep disabled in production.
LEGACY_AUTH_ENABLED=false
